#!/bin/sh

set -e

VERSION=0.0.0

SELF_DIR="$(cd "$(dirname "$0")"; pwd)"
QD_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}/quickdashboard"

err() {
    echo "ERROR: $1" >&2
    exit 1
}

if [ "$1" = "--version" ] || [ "$1" = "-v" ]; then
    echo "quickdashboard $VERSION"
    exit 0
fi

if [ -n "$QD_SOURCE_DIR" ]; then
    # Validate QD_SOURCE_DIR and convert it to absolute directory
    if ! QD_SOURCE_DIR="$(cd "$QD_SOURCE_DIR" && pwd)"; then
        err "bad QD_SOURCE_DIR directory was specified."
    fi
else
    QD_SOURCE_DIR="/usr/share/quickdashboard"
fi

provision() {
    TYPE="$1"
    NAME="$2"
    if [ ! -e "$QD_SOURCE_DIR/$NAME" ]; then
        err "could not find '$NAME' in the source dir '$QD_SOURCE_DIR"
    fi
    if [ ! -e "$QD_ROOT/$NAME" ]; then
        if [ "$TYPE" = "file" ]; then
            if ! cp "$QD_SOURCE_DIR/$NAME" "$QD_ROOT/$NAME"; then
                err "failed to copy the file from '$QD_SOURCE_DIR/$NAME' to '$QD_ROOT/$NAME'"
            fi
        elif [ "$TYPE" = "link" ]; then
            if ! ln -s "$QD_SOURCE_DIR/$NAME" "$QD_ROOT"; then
                err "failed to create the link for '$QD_SOURCE_DIR/$NAME' in '$QD_ROOT'"
            fi
        else
            err "unknown type '$TYPE'"
        fi
        return
    fi
    if [ "$TYPE" = "file" ]; then
        if [ ! -f "$QD_ROOT/$NAME" ] || [ ! -r "$QD_ROOT/$NAME" ]; then
            err "'${QD_ROOT}/${NAME}' is not a file or is unreadable"
        fi
    elif [ "$TYPE" = "link" ]; then
        if [ ! -L "$QD_ROOT/$NAME" ]; then
            err "'${QD_ROOT}/${NAME}' is not a symlink"
        fi
    else
        err "unknown type '$TYPE'"
    fi
}

if [ -e "$SELF_DIR/../shell.qml" ] && [ -d "$SELF_DIR/../qd" ]; then
    QD_SOURCE_DIR="$(cd "$SELF_DIR/.."; pwd)"
    exec quickshell --path "$QD_SOURCE_DIR" "$@"
fi

if [ ! -e "$QD_ROOT" ]; then
    mkdir -p "$QD_ROOT"
elif [ ! -d "$QD_ROOT" ]; then
    err "quickdashboard root '$QD_ROOT' exists and is not a directory"
fi

provision file "theme.json"
provision file "widget.json"
provision file "defaults.json"
if [ ! -e "$QD_ROOT/shell.qml" ]; then
    provision file "DashboardDefault.qml"
    provision file "shell.qml"
fi
provision link "qd"

[ -e "$QD_ROOT/.qmlls.ini" ] || touch "$QD_ROOT/.qmlls.ini"

exec quickshell --path "$QD_ROOT" "$@"
